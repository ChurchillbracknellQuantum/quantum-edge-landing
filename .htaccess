# Route sitemap.xml through PHP — guarantees correct Content-Type on any host
RewriteEngine On
RewriteRule ^sitemap\.xml$ sitemap.php [L,QSA]

# ---- Clean URLs (no .html) -------------------------------------------------
# 1) Redirect /index.html and /dir/index.html to the directory root
RewriteCond %{THE_REQUEST} \s/+(.*/)?index\.html[\s?] [NC]
RewriteRule ^ /%1 [R=301,L]
# 2) Redirect any other /page.html to /page (301 keeps SEO + old links working)
RewriteCond %{THE_REQUEST} \s/+([^?\s]+)\.html[\s?] [NC]
RewriteRule ^ /%1 [R=301,L]
# 3) Internally serve the matching .html file for an extensionless request
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.html -f
RewriteRule ^(.+?)/?$ $1.html [L]
# ---------------------------------------------------------------------------

# Custom branded 404 page
ErrorDocument 404 /404.html

# Cache control for HTML pages (only if mod_headers available)
# Short max-age + must-revalidate so edits show within ~10 min, not 1 hour
<IfModule mod_headers.c>
<FilesMatch "\.(html|htm)$">
  Header set Cache-Control "public, max-age=600, must-revalidate"
</FilesMatch>
</IfModule>

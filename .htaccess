# Route sitemap.xml through PHP — guarantees correct Content-Type on any host
RewriteEngine On
RewriteRule ^sitemap\.xml$ sitemap.php [L,QSA]

# Custom branded 404 page
ErrorDocument 404 /404.html

# Cache control for HTML pages (only if mod_headers available)
# Short max-age + must-revalidate so edits show within ~10 min, not 1 hour
<IfModule mod_headers.c>
<FilesMatch "\.(html|htm)$">
  Header set Cache-Control "public, max-age=600, must-revalidate"
</FilesMatch>
</IfModule>
